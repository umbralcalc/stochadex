#!/bin/sh
# After any commit that changes the repo beyond template/go.{mod,sum}, pin
# template/ to the current stochadex HEAD and create a follow-up commit if
# needed. Keeps the template module bump as the last commit in the chain.
#
# Disable: SKIP_TEMPLATE_BUMP_HOOK=1 git commit ...
# Install:  git config core.hooksPath scripts/git-hooks
#           chmod +x scripts/git-hooks/post-commit

set -e

if [ -n "$SKIP_TEMPLATE_BUMP_HOOK" ]; then
	exit 0
fi

REPO_ROOT=$(git rev-parse --show-toplevel) || exit 0
export REPO_ROOT
cd "$REPO_ROOT" || exit 0

# Avoid infinite loop: this commit only touched template module pins.
FILES=$(git diff-tree --no-commit-id --name-only -r HEAD)
if [ -z "$FILES" ]; then
	exit 0
fi

NON_PIN=
for f in $FILES; do
	case "$f" in
	template/go.mod|template/go.sum) ;;
	*) NON_PIN=1; break ;;
	esac
done

if [ -z "$NON_PIN" ]; then
	exit 0
fi

cd "$REPO_ROOT/template" || exit 0

cleanup_replace() {
	go mod edit -dropreplace=github.com/umbralcalc/stochadex 2>/dev/null || true
}

trap cleanup_replace EXIT

go mod edit -replace=github.com/umbralcalc/stochadex=..
HEAD_SHA=$(git -C "$REPO_ROOT" rev-parse HEAD)
if ! go get "github.com/umbralcalc/stochadex@$HEAD_SHA"; then
	echo "post-commit: go get stochadex@HEAD failed (template bump aborted)" >&2
	exit 1
fi

go mod tidy
go mod edit -dropreplace=github.com/umbralcalc/stochadex
trap - EXIT

if ! go mod tidy; then
	echo "post-commit: go mod tidy failed after dropreplace." >&2
	echo "  New pseudo-versions may need network access (or push HEAD first)." >&2
	exit 1
fi

cd "$REPO_ROOT" || exit 0

if git diff --quiet -- template/go.mod template/go.sum; then
	exit 0
fi

git add template/go.mod template/go.sum
# --no-verify: avoid pre-commit / other hooks re-entering this flow oddly
git commit --no-verify -m "chore(template): bump stochadex module to HEAD"

exit 0
