*.zip
data/*
__pycache__/
*.pyc
.ipynb_checkpoints
bin/
tmp/
# Compiled CLI binaries: `go build` in a cmd/ dir drops the binary beside its source,
# and the release workflow builds into cmd/stochadex/dist/.
/cmd/*/dist/
/cmd/stochadex/stochadex
.vscode/
nbs/data/*
log/*
.DS_Store

# Generated docs site output — built by docs/build.sh and published to gh-pages by
# CI. Not served from main (Pages serves gh-pages), so keep only sources in the repo.
docs/index.html
docs/pkg/
docs/sitemap.xml
docs/robots.txt
docs/model-index.json
